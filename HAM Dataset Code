        "# ----------------------------------------------------\n",
        "# SQUARE ONE: THE OFFICIAL \"ALL-HAM\" GENERATOR\n",
        "# ----------------------------------------------------\n",
        "import pandas as pd\n",
        "import re\n",
        "from google.colab import files\n",
        "\n",
        "print(\"📬 Step 1: Opening the massive raw 'enron_spam_data.csv' file...\")\n",
        "# Read straight from your uploaded master file\n",
        "df_raw = pd.read_csv('enron_spam_data.csv')\n",
        "\n",
        "# Instantly drop any broken rows where the text content is missing completely\n",
        "df_raw = df_raw.dropna(subset=['Message'])\n",
        "\n",
        "print(\"🔍 Step 2: Isolating the clean legitimate pool...\")\n",
        "# Target ONLY the 'ham' emails for this specific study baseline\n",
        "ham_pool = df_raw[df_raw['Spam/Ham'] == 'ham']\n",
        "\n",
        "print(f\"   (Found a total of {len(ham_pool)} human ham emails available)\")\n",
        "\n",
        "print(\"⚖️ Step 3: Extracting exactly 866 rows from the legimate pool...\")\n",
        "# Sampling a perfect 866 to match your total sample size benchmark\n",
        "all_ham_df = ham_pool.sample(n=866, random_state=42).reset_index(drop=True)\n",
        "\n",
        "print(\"🧼 Step 4: Normalizing text formatting to make it comprehensible for the AI...\")\n",
        "# This function flattens raw text down into clean, single-spaced sentences\n",
        "def clean_text_from_scratch(text):\n",
        "    if not isinstance(text, str):\n",
        "        return \"\"\n",
        "    # Flatten out weird double spaces, system formatting symbols, and line breaks\n",
        "    text = re.sub(r'\\s+', ' ', text)\n",
        "    return text.strip()\n",
        "\n",
        "# Apply the deep cleaning process to every single selected row\n",
        "all_ham_df['Clean_Message'] = all_ham_df['Message'].apply(clean_text_from_scratch)\n",
        "\n",
        "print(\"🎲 Step 5: Shuffling all the cards...\")\n",
        "# Randomizes the row order completely so it's ready for a clean sequence run\n",
        "all_ham_df = all_ham_df.sample(frac=1, random_state=42).reset_index(drop=True)\n",
        "\n",
        "# Save everything into your custom-named file\n",
        "output_filename = 'all_ham_dataset.csv'\n",
        "all_ham_df.to_csv(output_filename, index=False)\n",
        "\n",
        "print(\"\\n==================================================\")\n",
        "print(\"🎉 SUCCESS! THE 'ALL-HAM' DATASET IS READY!\")\n",
        "print(\"==================================================\")\n",
        "print(f\"📊 Total Emails Packed: {len(all_ham_df)}\")\n",
        "print(all_ham_df['Spam/Ham'].value_counts().to_string())\n",
        "print(f\"\\n💾 Saved permanently as: '{output_filename}'\")\n",
        "\n",
        "# Trigger the automatic browser download to your computer\n",
        "files.download(output_filename)"
