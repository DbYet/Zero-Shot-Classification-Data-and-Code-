        "import pandas as pd\n",
        "from transformers import pipeline\n",
        "from tqdm import tqdm\n",
        "from sklearn.metrics import accuracy_score, precision_recall_fscore_support\n",
        "\n",
        "# --- CONFIGURATION PARAMETERS ---\n",
        "# Set DEVICE = 0 for GPU (highly recommended for large models) or -1 for CPU\n",
        "DEVICE = 0\n",
        "DATASET_FILE = \"all_ham_dataset.csv\"\n",
        "TARGET_COLUMN = \"Clean_Message\"\n",
        "GROUND_TRUTH_COLUMN = \"Spam/Ham\"\n",
        "CANDIDATE_LABELS = [\"ham\", \"spam\"]\n",
        "TRUNCATION_LIMIT = 1500\n",
        "OUTPUT_FILE = \"all_ham_dataset_zero_shot_results.csv\"\n",
        "\n",
        "# 1. Load Dataset\n",
        "print(f\"Loading dataset: {DATASET_FILE}...\")\n",
        "df = pd.read_csv(DATASET_FILE)\n",
        "\n",
        "# 2. Initialize Models independently\n",
        "# Model 1: BART\n",
        "print(\"Initializing BART (facebook/bart-large-mnli)...\")\n",
        "bart_pipe = pipeline(\"zero-shot-classification\", model=\"facebook/bart-large-mnli\", device=DEVICE)\n",
        "\n",
        "# Model 2: RoBERTa\n",
        "print(\"Initializing RoBERTa (FacebookAI/roberta-large-mnli)...\")\n",
        "roberta_pipe = pipeline(\"zero-shot-classification\", model=\"FacebookAI/roberta-large-mnli\", device=DEVICE)\n",
        "\n",
        "# Model 3: DeBERTa\n",
        "print(\"Initializing DeBERTa (MoritzLaurer/DeBERTa-v3-base-mnli-fever-anli)...\")\n",
        "deberta_pipe = pipeline(\"zero-shot-classification\", model=\"MoritzLaurer/DeBERTa-v3-base-mnli-fever-anli\", device=DEVICE)\n",
        "\n",
        "# 3. Execution Pipeline\n",
        "bart_preds, roberta_preds, deberta_preds = [], [], []\n",
        "\n",
        "print(\"Starting Zero-Shot Classification benchmarks...\")\n",
        "for text in tqdm(df[TARGET_COLUMN].astype(str), desc=\"Processing Messages\"):\n",
        "    # Text Truncation Guardrail\n",
        "    clean_text = text[:TRUNCATION_LIMIT]\n",
        "\n",
        "    # Model Inference - Extracting the top label (index 0 of sorted labels)\n",
        "    bart_preds.append(bart_pipe(clean_text, CANDIDATE_LABELS)['labels'][0])\n",
        "    roberta_preds.append(roberta_pipe(clean_text, CANDIDATE_LABELS)['labels'][0])\n",
        "    deberta_preds.append(deberta_pipe(clean_text, CANDIDATE_LABELS)['labels'][0])\n",
        "\n",
        "# 4. Data Assembly & Save\n",
        "df['BART_Prediction'] = bart_preds\n",
        "df['RoBERTa_Prediction'] = roberta_preds\n",
        "df['DeBERTa_Prediction'] = deberta_preds\n",
        "\n",
        "df.to_csv(OUTPUT_FILE, index=False)\n",
        "print(f\"\\nFull results exported to {OUTPUT_FILE}\")\n",
        "\n",
        "# 5. Advanced Metrics Evaluation Block\n",
        "print(\"\\n--- PERFORMANCE SUMMARY REPORT ---\")\n",
        "models_to_eval = [\"BART\", \"RoBERTa\", \"DeBERTa\"]\n",
        "\n",
        "for model_name in models_to_eval:\n",
        "    pred_col = f\"{model_name}_Prediction\"\n",
        "\n",
        "    # Calculate metrics\n",
        "    acc = accuracy_score(df[GROUND_TRUTH_COLUMN], df[pred_col])\n",
        "    prec, rec, f1, _ = precision_recall_fscore_support(\n",
        "        df[GROUND_TRUTH_COLUMN],\n",
        "        df[pred_col],\n",
        "        average='weighted',\n",
        "        labels=CANDIDATE_LABELS\n",
        "    )\n",
        "\n",
        "    print(f\"\\nModel: {model_name}\")\n",
        "    print(f\"- Overall Accuracy: {acc:.4f}\")\n",
        "    print(f\"- Weighted Precision: {prec:.4f}\")\n",
        "    print(f\"- Weighted Recall: {rec:.4f}\")\n",
        "    print(f\"- Weighted F1-Score: {f1:.4f}\")"
      ]
